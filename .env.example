# ─────────────────────────────────────────────────────────────
# landholder.com — environment
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# All keys are read SERVER-SIDE only (no NEXT_PUBLIC_ prefix).
# ─────────────────────────────────────────────────────────────

# Master switch. `true` = run entirely on mocks + free sources (no paid keys
# needed). Flip to `false` once Regrid / Google keys are in place to go live.
USE_MOCKS=true

# ── PAID KEYS (the only two that cost money) ──────────────────
# Regrid — THE ANCHOR. Parcel geometry, acreage, owner, zoning (FAR/setbacks/uses).
# Nothing downstream works without this once USE_MOCKS=false.
# https://regrid.com/api
REGRID_API_TOKEN=

# Google — Geocoding fallback + Places (grocery/POIs).
# Census geocoder covers geocoding for free; Google is the fallback + amenities.
# https://developers.google.com/maps/documentation
GOOGLE_MAPS_API_KEY=

# ── FREE KEYS (registration only, no cost) ────────────────────
# US Census Data API — county population / demographics / income.
# Free, but the Census data API now REQUIRES a key (it used to be keyless).
# Get one in ~2 min: https://api.census.gov/data/key_signup.html
# Census is decoupled from USE_MOCKS — once this key is set, real demographics
# light up even while everything else stays on mock/free data.
CENSUS_API_KEY=
# Set USE_CENSUS=false to force mock demographics even when a key is present.
USE_CENSUS=true

# ── DATABASE (Railway Postgres + PostGIS cache) ──────────────
# Raw Postgres connection string. On Railway, reference the DB service's
# variable so it stays in sync: DATABASE_URL = ${{ Postgres.DATABASE_URL }}
# Leave blank locally to use the in-memory cache fallback (dev only).
DATABASE_URL=
# Set true when connecting over Railway's PUBLIC proxy host (TLS required).
# Leave false/empty when the app talks to the DB over the private
# *.railway.internal network (same project) or to localhost.
DATABASE_SSL=

# ── Cache TTL for the Site Profile, in days ──────────────────
# Parcel-level data barely changes; 30–90 days is fine.
SITE_PROFILE_TTL_DAYS=60
